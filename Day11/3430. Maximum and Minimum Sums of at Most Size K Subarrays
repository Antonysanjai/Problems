class Solution {
    public long minMaxSubarraySum(int[] nums, int k) {
        return getSum(nums, k, true) + getSum(nums, k, false);
    }

    private long getSum(int[] nums, int k, boolean findMax) {
        int n = nums.length;
        int[] left = new int[n];
        int[] right = new int[n];
        Stack<Integer> stack = new Stack<>();

   
        for (int i = 0; i < n; i++) {
            while (!stack.isEmpty() && (findMax ? nums[stack.peek()] <= nums[i] : nums[stack.peek()] >= nums[i])) {
                stack.pop();
            }
            left[i] = stack.isEmpty() ? i : i - stack.peek() - 1;
            stack.push(i);
        }

        stack.clear();

   
        for (int i = n - 1; i >= 0; i--) {
            while (!stack.isEmpty() && (findMax ? nums[stack.peek()] < nums[i] : nums[stack.peek()] > nums[i])) {
                stack.pop();
            }
            right[i] = stack.isEmpty() ? n - 1 - i : stack.peek() - i - 1;
            stack.push(i);
        }

     
        long totalSum = 0;
        for (int i = 0; i < n; i++) {
            long count = countSubarrays(left[i], right[i], k);
            totalSum += count * nums[i];
        }

        return totalSum;
    }

   
    private long countSubarrays(long L, long R, int k) {
        long count = 0;
       
        for (int l = 0; l <= L && l < k; l++) {
            long maxR = Math.min(R, k - 1 - l);
            count += (maxR + 1);
        }
        return count;
    }
}
